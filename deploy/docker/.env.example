# VibeShop Docker 环境变量模板
# 用法：
#   cp deploy/docker/.env.example deploy/docker/.env
#   编辑 .env 文件，填入真实密码
#   .env 已加入 .gitignore，不会提交
#
# 生成强密码: openssl rand -base64 24

# ====== MySQL ======
VIBESHOP_MYSQL_ROOT_PASSWORD=
VIBESHOP_MYSQL_USER=vibeshop
VIBESHOP_MYSQL_PASSWORD=

# ====== PostgreSQL ======
VIBESHOP_PG_USER=vibeshop
VIBESHOP_PG_PASSWORD=

# ====== Redis ======
VIBESHOP_REDIS_PASSWORD=

# ====== JWT ======
# 至少 32 字符: openssl rand -base64 48
VIBESHOP_JWT_SECRET=

# ====== 可选 ======
# APP_HOST_PORT=8080
# VERSION=dev

# 中间件主机端口（避免与本机/Windows 已有服务冲突时使用错位端口）
# 容器内端口仍为标准端口（mysql:3306/postgres:5432/redis:6379/nats:4222）
# VIBESHOP_MYSQL_HOST_PORT=3307
# VIBESHOP_PG_HOST_PORT=5433
# VIBESHOP_REDIS_HOST_PORT=6380
# VIBESHOP_NATS_HOST_PORT=4223
# VIBESHOP_NATS_MON_HOST_PORT=8223
