# .gitignore

# Binaries
bin/
*.exe
*.dll
*.so
*.dylib

# Go
vendor/
*.test
*.out

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.production
# 含真实密钥的配置文件，不提交仓库（使用 *.example 模板）
configs/dev.yaml
configs/docker.yaml
configs/prod.yaml
deploy/docker/.env

# Node
node_modules/
web/.next/
web/out/
mobile/dist/
mobile/unpackage/

# Build
dist/
build/

# Uploads (dev)
uploads/

# Database files
*.db
*.sqlite

# Logs
logs/
*.log

# Private internal docs (tickets / security remediation / internal scan records)
docs/private/

# Docker
docker-compose.override.yml
vibeshop

# AI agent local state (do not commit)
# .ccb/ 是本地 CCB 工作区与运行态产物（daemon socket / lifecycle / 会话日志 / 本机 agent 配置）
# .claude/settings.local.json 是 Claude Code 本机权限白名单缓存
.ccb/
.claude/settings.local.json
